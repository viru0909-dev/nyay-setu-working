# NLP Orchestrator Environment Variables
# Copy this file to .env and fill in your actual values

# Required API Keys
# Get your free Groq API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Optional — Gemini is used for deeper reasoning; falls back to Groq if unset
# Get your Gemini API key at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Indian Kanoon API (recommended)
# Used to ground responses with real judgments and statute sections
# Register for a token at: https://api.indiankanoon.org
INDIAN_KANOON_TOKEN=your_indian_kanoon_token_here
INDIAN_KANOON_API_URL=https://api.indiankanoon.org

# Optional: Hugging Face (for gated/private models like trocr-sanskrit-ocr)
HF_TOKEN=
TROCR_MODEL_NAME=Piyush3142/trocr-sanskrit-ocr
TROCR_DEVICE=

# Configurable concurrency set to the min(number of system cores, 8)
OCR_MAX_CONCURRENCY=1

# CORS Configuration
# Origin allowed to call this service (your frontend URL)
FRONTEND_ORIGIN=http://localhost:5173

# Retrieval / RAG settings
RERANKER_MODEL=BAAI/bge-reranker-base
RETRIEVAL_FETCH_K=20
RETRIEVAL_TOP_K=5
