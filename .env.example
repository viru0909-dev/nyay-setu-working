# Database Configuration
DB_NAME=nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=postgres

# AI Service Keys (Required for NLP and Analysis)
# REQUIRED: set valid API keys before starting services
# Get your free key at: https://console.groq.com
# Leave empty; set a real value in your local .env file
GROQ_API_KEY=
# Leave empty; set a real value in your local .env file
GOOGLE_GEMINI_API_KEY=

# Security
# REQUIRED: Random string for JWT signing. 
# Leave empty; set a strong secret in your local .env file
JWT_SECRET=

# Networking
# Use http://localhost for Docker setup
FRONTEND_URL=http://localhost
FRONTEND_ORIGIN=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost
SPRING_PROFILES_ACTIVE=dev

# Frontend API Configuration
VITE_API_URL=http://localhost:9000
REACT_APP_API_BASE_URL=http://localhost:9000
