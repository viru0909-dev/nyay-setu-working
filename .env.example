# Database Configuration
DB_NAME=nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=postgres

# AI Service Keys (Required for NLP and Analysis)
# REQUIRED: set valid API keys before starting services
# Get your free key at: https://console.groq.com
# Leave empty; set a real value in your local .env file
GROQ_API_KEY=
# Leave empty; set a real value in your local .env file
GOOGLE_GEMINI_API_KEY=

# Security
# REQUIRED: Random string for JWT signing. 
# Leave empty; set a strong secret in your local .env file
JWT_SECRET=

# Networking
# Use http://localhost for Docker setup
FRONTEND_URL=http://localhost
FRONTEND_ORIGIN=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost
SPRING_PROFILES_ACTIVE=dev

# Frontend API Configuration
VITE_API_URL=http://localhost:9000
REACT_APP_API_BASE_URL=http://localhost:9000
VITE_API_BASE_URL=http://localhost:8080
VITE_LAWGPT_BASE=http://localhost:8001
VITE_NLP_BASE_URL=http://localhost:8001

# Backend API base URL used by React at runtime
# Keep in sync with VITE_API_URL
REACT_APP_API_BASE_URL=http://localhost:9000

# Redis Cache
# Used to cache LLM responses (24h) and embeddings (7 days) to reduce API costs
# For local dev without Docker: redis://localhost:6379/0
# For Docker Compose: redis://redis:6379/0 (set automatically in docker-compose.yml)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=86400
EMBEDDING_CACHE_TTL_SECONDS=604800
