# ─────────────────────────────────────────────
# Database Configuration
# ─────────────────────────────────────────────

# PostgreSQL database name (create this before running the app)
DB_NAME=nyaysetu

# PostgreSQL username with full privileges on DB_NAME
DB_USERNAME=postgres

# Password for the PostgreSQL user above
DB_PASSWORD=postgres

# ─────────────────────────────────────────────
# AI Service Keys (Required for NLP and Analysis)
# ─────────────────────────────────────────────

# Groq API key — powers the Vakil Friend AI legal assistant
# REQUIRED: set a valid key before starting services
# Get your free key at: https://console.groq.com
# Leave empty; set a real value in your local .env file
GROQ_API_KEY=

# Local-only multilingual PII model and backend-to-orchestrator endpoint
PII_NER_MODEL=ai4bharat/IndicNER
PII_NER_URL=http://backend-python:8001/internal/pii/entities

# Google Gemini API key — used for additional AI analysis features
# Get your key at: https://aistudio.google.com/app/apikey
# Leave empty; set a real value in your local .env file
GOOGLE_GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────

# Secret key used by Spring Boot to sign and verify JWT tokens
# REQUIRED: use a long random string (minimum 32 characters)
# Example: openssl rand -base64 32
# Leave empty; set a strong secret in your local .env file
JWT_SECRET=

# ─────────────────────────────────────────────
# Google OAuth 2.0 (Required for "Sign in with Google")
# ─────────────────────────────────────────────

# OAuth 2.0 Client ID from Google Cloud Console
# Steps: https://console.cloud.google.com/apis/credentials
#  1. Create a project (or select an existing one)
#  2. Enable the "Google+ API" / "Google Identity" scopes
#  3. Create OAuth 2.0 credentials (type: Web application)
#  4. Add authorised redirect URI: http://localhost:8080/login/oauth2/code/google
# Leave empty; set real values in your local .env file
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────
# Networking
# ─────────────────────────────────────────────

# Base URL of the React frontend (used by backend for redirects)
# Use http://localhost for local dev, update for Docker or production
FRONTEND_URL=http://localhost

# Allowed origin for the frontend (used in CORS configuration)
FRONTEND_ORIGIN=http://localhost

# Comma-separated list of origins allowed to make cross-origin requests
# For local dev, localhost is sufficient
CORS_ALLOWED_ORIGINS=http://localhost

# Spring Boot active profile — controls which config file is loaded
# Options: dev | prod | docker
SPRING_PROFILES_ACTIVE=dev

# ─────────────────────────────────────────────
# Frontend API Configuration
# ─────────────────────────────────────────────

# Backend API base URL used by Vite during development
# Should match the port Spring Boot is running on (default: 9000)
VITE_API_URL=http://localhost:9000
REACT_APP_API_BASE_URL=http://localhost:9000
VITE_API_BASE_URL=http://localhost:8080
VITE_LAWGPT_BASE=http://localhost:8001
VITE_NLP_BASE_URL=http://localhost:8001

# Backend API base URL used by React at runtime
# Keep in sync with VITE_API_URL
REACT_APP_API_BASE_URL=http://localhost:9000

# Semantic Redis cache for reusable legal AI queries
SEMANTIC_CACHE_LEGAL_ENABLED=true
SEMANTIC_CACHE_LEGAL_TTL_SECONDS=86400
SEMANTIC_CACHE_LEGAL_SIMILARITY_THRESHOLD=0.82
SEMANTIC_CACHE_LEGAL_MAX_CANDIDATES=200
SEMANTIC_CACHE_LEGAL_MIN_QUERY_LENGTH=8
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth service integration
AUTH_SERVICE_URL=http://localhost:8080

# NLP retrieval embedding model
EMBEDDING_MODEL=law-ai/InLegalBERT
