# Example environment variables for nyaysetu-backend
# NOTE: Keep this file non-sensitive. Use real secrets via your deployment env vars.

# JWT
JWT_SECRET=nyaysetu-2024-secure-jwt-signing-key-minimum-256-bits-required
JWT_EXPIRATION_MS=86400000

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4174,http://localhost:3000

# Database
DB_URL=jdbc:postgresql://localhost:5432/nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Ollama (Local AI)
# Used when AI_PROVIDER=ollama
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b
AI_PROVIDER=ollama

# Groq (Optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Azure OpenAI / Document Intelligence (Optional)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=nyay-gpt
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

# Gemini/OpenAI (Optional)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Other
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FRONTEND_URL=http://localhost:5173

