# NYAY-SETU Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration (Local)
DB_URL=jdbc:postgresql://localhost:5432/nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=your_password

# JWT Security
JWT_SECRET=your-secure-jwt-secret-key-minimum-256-bits

# AI Configuration (Recommended: Groq)
# Get your free API key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
# Optional/Legacy AI Services
GEMINI_API_KEY=your-gemini-api-key-here
# Azure Document Intelligence (Optional)
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=

# CORS Configuration (Production)
# Change these to your actual Vercel/Render URLs
CORS_ALLOWED_ORIGINS=https://nyay-setu-frontend-coral.vercel.app,http://localhost:5173
FRONTEND_URL=https://nyay-setu-frontend-coral.vercel.app

# Database & Flyway
SHOW_SQL=false
FLYWAY_URL=
FLYWAY_USER=
FLYWAY_PASSWORD=

# JWT Expiration Time (in milliseconds)
JWT_EXPIRATION_MS=86400000

# Legacy/Alternative AI Services
OPENAI_API_KEY=your-openai-api-key-here
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:1b

# Azure AI Configuration
AZURE_OPENAI_ENDPOINT=https://uaenorth.api.cognitive.microsoft.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=nyay-gpt

# Bhashini Translation API Configuration
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_PIPELINE_ID=

# SMTP Configuration (for verification and reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
