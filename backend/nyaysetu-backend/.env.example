# ===============================
# DATABASE CONFIGURATION
# ===============================
DB_NAME=nyaysetu
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ===============================
# AI SERVICE KEYS
# ===============================
# REQUIRED: set valid API keys before starting services
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# Google Gemini API Key
GOOGLE_GEMINI_API_KEY=

# ===============================
# SECURITY
# ===============================
# REQUIRED: Random string for JWT signing
JWT_SECRET=

# JWT Expiration (24 Hours)
JWT_EXPIRATION=86400000

# ===============================
# GOOGLE OAUTH2
# ===============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===============================
# NETWORKING
# ===============================
# Use localhost URLs for development

FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===============================
# SPRING PROFILE
# ===============================
SPRING_PROFILES_ACTIVE=dev

# ===============================
# MISSING VALIDATION KEYS
# ===============================
AI_PROVIDER=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=
BHASHINI_API_KEY=
BHASHINI_PIPELINE_ID=
BHASHINI_USER_ID=
DB_URL=
FLYWAY_PASSWORD=
FLYWAY_URL=
FLYWAY_USER=
JWT_EXPIRATION_MS=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
OPENAI_API_KEY=
SHOW_SQL=
SMTP_HOST=
SMTP_PASSWORD=
SMTP_PORT=
SMTP_USERNAME=

# Semantic Redis cache for reusable legal AI queries
SEMANTIC_CACHE_LEGAL_ENABLED=true
SEMANTIC_CACHE_LEGAL_TTL_SECONDS=86400
SEMANTIC_CACHE_LEGAL_SIMILARITY_THRESHOLD=0.82
SEMANTIC_CACHE_LEGAL_MAX_CANDIDATES=200
SEMANTIC_CACHE_LEGAL_MIN_QUERY_LENGTH=8
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth service integration
AUTH_SERVICE_URL=http://localhost:8080
